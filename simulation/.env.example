# TIPA V2.0 simulation (Node-RED) env TEMPLATE — placeholders only (real .env on the VM, chmod 600).
#   cd simulation && docker compose -f docker-compose.sim.yml --env-file .env up -d

TZ=Asia/Ho_Chi_Minh
# Host port for the Node-RED editor/dashboard (verified free; NEVER 1880).
NODERED_PORT=1881
# Node-RED credential encryption secret (generate on the VM: openssl rand -hex 24).
NODE_RED_CREDENTIAL_SECRET=__CHANGE_ME_RANDOM_SECRET__
# MDP V2 target for the simulation flow (internal name of the MDP Caddy edge on mdpv2_default).
MDP_BASE_URL=http://reverse-proxy:8456
# Inbound-scoped API key for the `sim_reading` model (created via the MDP API on the VM).
MDP_INBOUND_KEY=__CHANGE_ME_INBOUND_API_KEY__
