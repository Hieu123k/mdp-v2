# TIPA V2.0 — DEV compose env TEMPLATE (placeholders only — NEVER put real secrets here).
# Copy to `ops/.env`, fill REAL values on the VM (the two *_SECRET_KEY >= 32 random chars),
# then `chmod 600 ops/.env`. The real `.env` is git-ignored and must never be committed.
#
#   cd ops && docker compose -f docker-compose.v2.yml --env-file .env up -d --build

APP_ENV=production

# --- Postgres (V2-isolated; not published to the host) ---
POSTGRES_DB=mdp
POSTGRES_USER=mdp_user
POSTGRES_PASSWORD=__CHANGE_ME_STRONG_PG_PWD__
# Must embed the SAME password as POSTGRES_PASSWORD; host = the compose service name `postgres`.
DATABASE_URL=postgresql+psycopg://mdp_user:__CHANGE_ME_STRONG_PG_PWD__@postgres:5432/mdp

# --- App secrets (>= 32 random chars each; production config rejects the defaults) ---
JWT_SECRET_KEY=__CHANGE_ME_RANDOM_AT_LEAST_32_CHARS__
CONNECTION_SECRET_KEY=__CHANGE_ME_RANDOM_AT_LEAST_32_CHARS__

# --- CORS / edge ---
# Host port for the V2 stack (V1 mdp2 keeps :8456; pick a free port to coexist).
MDP_V2_PORT=8457
CORS_ORIGINS=["http://127.0.0.1:8457","http://192.168.2.170:8457"]

# --- Background loops — keep OFF in P0 (no Oracle/ingestion yet; Flink replaces ora2pg in V2) ---
STREAMING_ENABLED=false
STREAMING_INTERVAL=60
ORA2PG_SOURCE_COUNT_ENABLED=false
