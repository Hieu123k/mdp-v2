# Prompt 31 — prod-safe simulator env TEMPLATE (placeholders only — NEVER commit real values).
# Copy to ops/sim/.env on the host, fill, then chmod 600. The real .env is git-ignored.

# Timezone for generated business timestamps.
TZ=Asia/Ho_Chi_Minh

# Node-RED credential-encryption secret (any long random string). Not strictly required (no real creds).
NODE_RED_CREDENTIAL_SECRET=__CHANGE_ME_RANDOM__

# MDP edge the flow POSTs to (in-network service name; do NOT hardcode a public IP).
MDP_BASE_URL=http://reverse-proxy:8456

# The MDP compose network to JOIN (external). Prod = mdp_default ; mdp2 test = mdpv2_default.
MDP_NETWORK=mdp_default

# Host port for /ui. Prod = 1881 (NEVER 1880). mdp2 test = 1882 (1881 is the existing DEV sim).
SIM_PORT=1881

# Acc inbound key VALUES as a JSON object {label: value}, taken from the bootstrap output. RUNTIME ONLY.
# Example shape (use your real values from bootstrap_accounting_models on the host, never commit them):
#   MDP_ACC_KEYS={"acc_in_acc_customer":"mdp_live_...","acc_in_acc_vendor":"mdp_live_...", ...}
MDP_ACC_KEYS=
