{
  "uid": "acc_sample",
  "title": "Accounting (Sample)",
  "tags": [
    "accounting",
    "sample",
    "report",
    "prompt31"
  ],
  "schemaVersion": 39,
  "version": 0,
  "timezone": "browser",
  "time": {
    "from": "now-1y",
    "to": "now"
  },
  "refresh": "",
  "templating": {
    "list": [
      {
        "name": "DS_POSTGRES",
        "label": "Postgres datasource",
        "type": "datasource",
        "query": "grafana-postgresql-datasource",
        "current": {},
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Revenue / Cost / Gross Profit",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "Revenue",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "format": "table",
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT 1 AS k, round(sum(amount)::numeric,2)::float8 AS \"Revenue\" FROM mdp_models.acc_ar_360 WHERE $__timeFilter(issue_date)"
        },
        {
          "refId": "Cost",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "format": "table",
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT 1 AS k, round(sum(amount)::numeric,2)::float8 AS \"Cost\" FROM mdp_models.acc_ap_360 WHERE $__timeFilter(issue_date)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "k",
            "mode": "outer"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "alias": "Gross Profit",
            "binary": {
              "left": "Revenue",
              "operator": "-",
              "right": "Cost"
            },
            "replaceFields": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "k": true
            }
          }
        }
      ]
    },
    {
      "id": 2,
      "title": "Revenue by Region (AR)",
      "type": "barchart",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "format": "table",
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT region, round(sum(amount)::numeric,2)::float8 AS revenue FROM mdp_models.acc_ar_360 WHERE $__timeFilter(issue_date) GROUP BY region ORDER BY revenue DESC LIMIT 1000"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Revenue over Time (AR)",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "format": "time_series",
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroup(issue_date, '1d') AS \"time\", round(sum(amount)::numeric,2)::float8 AS revenue FROM mdp_models.acc_ar_360 WHERE $__timeFilter(issue_date) GROUP BY 1 ORDER BY 1"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Top 10 Customers by Revenue (AR)",
      "type": "table",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "format": "table",
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT customer_name, round(sum(amount)::numeric,2)::float8 AS revenue FROM mdp_models.acc_ar_360 WHERE $__timeFilter(issue_date) GROUP BY customer_name ORDER BY revenue DESC LIMIT 10"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "AR Invoice Status",
      "type": "piechart",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "format": "table",
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT status, count(*) AS count FROM mdp_models.acc_ar_360 WHERE $__timeFilter(issue_date) GROUP BY status ORDER BY count DESC LIMIT 1000"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [],
          "values": true,
          "fields": "/^count$/"
        },
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ]
}