# TIPA V2.0 — PROD `.63` env TEMPLATE for docker-compose.prod63.yml + docker-compose.prod63-grafana.yml.
# PLACEHOLDERS ONLY — copy to `ops/.env.prod63` ON THE VM, fill REAL values, `chmod 600`, NEVER commit.
#
#   cd ops && docker compose -f docker-compose.prod63.yml         --env-file .env.prod63 up -d --build
#   cd ops && docker compose -f docker-compose.prod63-grafana.yml --env-file .env.prod63 up -d

# --- MDP app (docker-compose.prod63.yml) ---
APP_ENV=production
# Host port for the MDP Caddy edge on .63 (replaces v0.1.4 at :8456).
MDP_PORT=8456
# REUSE the existing prod Postgres (79 GB). Point at the reachable address of that DB — do NOT create a
# new volume. e.g. host-exposed:  postgresql+psycopg://mdp_user:__PROD_PG_PWD__@host.docker.internal:5432/mdp
DATABASE_URL=__PROD_POSTGRES_URL__
CORS_ORIGINS=["https://10.116.204.63:8456","http://10.116.204.63:8456"]
# REUSE the v0.1.4 secrets — changing them breaks existing API keys + logins.
JWT_SECRET_KEY=__REUSE_FROM_v0.1.4__
CONNECTION_SECRET_KEY=__REUSE_FROM_v0.1.4__
POSTGRES_PASSWORD=__PROD_PG_PWD__

# --- Oracle JDE `.16` (streaming + ora2pg source) ---
ORACLE_HOST=__10.116.204.16__
ORACLE_PORT=1521
ORACLE_SID=__TIPAORA__
ORACLE_SERVICE_NAME=
ORACLE_USER=__SET_ON_VM__
ORACLE_PWD=__SET_ON_VM__
ORACLE_SCHEMA=__JDE_SCHEMA__
ORA2PG_CONTAINER=ora2pg
ORA2PG_SOURCE_COUNT_ENABLED=false
# Master streaming switch (per-table enable is the real control via the UI switch). Default ON for prod.
STREAMING_ENABLED=true
STREAMING_INTERVAL=60

# --- Dedicated Grafana (docker-compose.prod63-grafana.yml) ---
GRAFANA_PORT=3001
GF_SERVER_ROOT_URL=https://10.116.204.63:3001
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=__SET_ON_VM__
# Outbound-scoped MDP API key for the Infinity datasource (create via the MDP API after cutover).
GRAFANA_MDP_API_KEY=__OUTBOUND_API_KEY__
# Read-only Postgres role for the optional Postgres datasource (create grafana_ro on the prod DB).
GRAFANA_DB_USER=grafana_ro
GRAFANA_DB_PASSWORD=__grafana_ro_PWD__
# The MDP prod stack's docker network (so Infinity reaches reverse-proxy:8456). `mdp_prod63_default`,
# or `mdp_default` if you started the MDP stack with `-p mdp`.
MDP_NETWORK=mdp_prod63_default
